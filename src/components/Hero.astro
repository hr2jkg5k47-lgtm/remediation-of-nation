---
interface Props {
  mode?: "project" | "person";
}
const { mode = "project" } = Astro.props;
---

{mode === "project" ? (
  <section id="top" class="min-h-screen flex items-center px-6 md:px-10 pt-24">
    <div class="mx-auto max-w-6xl w-full grid md:grid-cols-12 gap-10">
      <div class="md:col-span-11">
        <p class="text-xs uppercase tracking-[0.2em] text-[color:var(--color-muted)] mb-8">
          Current Research Project
        </p>
        <h1 class="font-display text-4xl md:text-6xl lg:text-7xl leading-[1.05] tracking-tight">
          The Remediation<br/>of Nation
        </h1>
        <p class="mt-10 max-w-2xl text-lg md:text-xl text-[color:var(--color-muted)] leading-relaxed">
          A study of how media — from 19th panoramas, to postwar radio
          and contemporary screen cultures — rehearse, repair, reform, and re-stage
          the idea of the nation.
        </p>
        <div class="mt-12 flex flex-wrap items-center gap-4">
          <a href="#project"
             class="inline-flex items-center gap-2 bg-[color:var(--color-ink)] text-[color:var(--color-paper)] px-6 py-3 text-sm tracking-wide hover:bg-[color:var(--color-accent)] transition-colors">
            About the Project
            <span aria-hidden="true">→</span>
          </a>
          <a href="#researcher"
             class="inline-flex items-center gap-2 border border-[color:var(--color-ink)] px-6 py-3 text-sm tracking-wide hover:bg-[color:var(--color-ink)] hover:text-[color:var(--color-paper)] transition-colors">
            About the Researcher
          </a>
        </div>
        <p class="mt-16 text-xs text-[color:var(--color-muted)] tracking-wide">
          A project by <span class="text-[color:var(--color-ink)]">Birgit Haberpeuntner</span>
          · Universität für Angewandte Kunst Wien, Abteilung Medientheorie
          · funded by the ÖAW APART-GSK Fellowship Programme
        </p>
      </div>
    </div>
  </section>
) : (
  <section id="top" class="min-h-screen flex items-center px-6 md:px-10 pt-24">
    <div class="mx-auto max-w-6xl w-full grid md:grid-cols-12 gap-10">
      <div class="md:col-span-10">
        <p class="text-xs uppercase tracking-[0.2em] text-[color:var(--color-muted)] mb-8">
          Research Fellow · Media &amp; Cultural Studies
        </p>
        <h1 class="font-display text-5xl md:text-7xl lg:text-8xl leading-[1.02] tracking-tight">
          Birgit<br/>Haberpeuntner
        </h1>
        <p class="mt-10 max-w-2xl text-lg md:text-xl text-[color:var(--color-muted)] leading-relaxed">
          Working at the intersection of media theory, translation, and the cultural histories
          of nationhood — with a particular interest in how sound and language carry collective time.
        </p>
        <div class="mt-12 flex flex-wrap items-center gap-4">
          <a href="#project"
             class="inline-flex items-center gap-2 bg-[color:var(--color-ink)] text-[color:var(--color-paper)] px-6 py-3 text-sm tracking-wide hover:bg-[color:var(--color-accent)] transition-colors">
            View Project
          </a>
          <a href="#contact"
             class="inline-flex items-center gap-2 border border-[color:var(--color-ink)] px-6 py-3 text-sm tracking-wide hover:bg-[color:var(--color-ink)] hover:text-[color:var(--color-paper)] transition-colors">
            Contact
          </a>
        </div>
      </div>
    </div>
  </section>
)}
