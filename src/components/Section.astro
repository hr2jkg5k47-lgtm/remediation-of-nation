---
interface Props {
  id: string;
  label: string;
  title: string;
  titleHref?: string;
  image?: { src: string; alt: string };
}
const { id, label, title, titleHref, image } = Astro.props;
---

<section id={id} class="px-6 md:px-10 py-24 md:py-32 border-t border-[color:var(--color-rule)]">
  <div class="mx-auto max-w-6xl grid md:grid-cols-12 gap-10">
    <div class="md:col-span-3">
      <p class="text-xs uppercase tracking-[0.2em] text-[color:var(--color-muted)]">{label}</p>
      <h2 class="font-display text-3xl md:text-4xl mt-3 leading-tight">
        {titleHref ? (
          <a href={titleHref} class="hover:text-[color:var(--color-accent)] transition-colors">{title}</a>
        ) : title}
      </h2>
      {image && (
        <img
          src={image.src}
          alt={image.alt}
          class="mt-6 w-full aspect-[3/4] object-cover object-top grayscale opacity-60"
        />
      )}
    </div>
    <div class="md:col-span-9">
      <slot />
    </div>
  </div>
</section>
